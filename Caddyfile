# IP-first deployment (no domain yet -> plain HTTP on :80).
# When a domain is ready, replace ":80" with "your-domain.com" and Caddy will
# obtain a Let's Encrypt certificate automatically.
:80 {
	encode gzip

	# API + uploaded files (Express serves /api/uploads/* statically)
	handle /api/* {
		reverse_proxy app:3000
	}

	# SPA: serve static build, fall back to index.html for client-side routing
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
