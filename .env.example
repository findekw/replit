# ============================================================================
# finde — environment variables (example / template)
# Copy to ".env" and fill real values. ".env" is gitignored — never commit it.
# ============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Express session signing secret (long random string)
SESSION_SECRET=change_me_to_a_long_random_string

# ── Database (self-hosted PostgreSQL on the VPS) ────────────────────────────
# NOTE: special characters in the password MUST be URL-encoded in the URL.
POSTGRES_USER=finde
POSTGRES_PASSWORD=change_me
POSTGRES_DB=finde
# host = "postgres" when running via docker-compose; "localhost" if native install
DATABASE_URL=postgres://finde:change_me@postgres:5432/finde
# Force standard node-postgres driver (self-hosted Postgres, not Neon serverless)
DATABASE_DRIVER=pg

# ── Object storage (self-hosted MinIO, S3-compatible) — replaces Google Cloud ─
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
S3_BUCKET=finde-uploads
S3_FORCE_PATH_STYLE=true
# Public base URL used to serve public objects (e.g. https://cdn.your-domain.com)
S3_PUBLIC_URL=

# ── Google OAuth (optional — only if Google login is used) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
